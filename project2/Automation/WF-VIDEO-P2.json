        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "{\n  \"text\": \"{{ $('Decode Job').item.json.script.full_narration }}\",\n  \"language\": \"en\",\n  \"voice\": \"Chelsie\",\n  \"style_instruction\": \"{{ $('Decode Job').item.json.narrationInstr }}\"\n}"
