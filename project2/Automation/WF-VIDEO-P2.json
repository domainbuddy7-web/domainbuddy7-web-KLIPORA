{
  "name": "Klipora WF-VIDEO-P2 — 5-Scene Video & Voice (Project 2)",
  "nodes": [
    {
      "id": "vid-1",
      "name": "Queue Poller",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [200, 300],
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 8,16 * * 0-6" }
          ]
        }
      }
    },
    {
      "id": "vid-check1",
      "name": "Check Time Window",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 300],
      "parameters": {
        "jsCode": "const now = new Date();\nconst localHour = (now.getUTCHours() + 4) % 24;\nconst localDate = new Date(now.getTime() + 4 * 60 * 60 * 1000);\nconst dateKey = localDate.toISOString().split('T')[0];\nconst inTimeWindow = localHour >= 12 && localHour < 20;\nreturn [{ json: { localHour, dateKey, inTimeWindow } }];"
      }
    },
    {
      "id": "vid-check2",
      "name": "GET Daily Count",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [600, 300],
      "parameters": {
        "method": "GET",
        "url": "https://wealthy-hyena-4511.upstash.io/get/p2:system:daily_count:{{ $json.dateKey }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "Bearer ARGfAAImcDE5NTI1MGEzYzhjMjQ0ZWM1YTFkYjY0ZmIxOTBhNmQ4YnAxNDUxMQ" }]
        }
      }
    },
    {
      "id": "vid-check3",
      "name": "Evaluate Limits",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, 300],
      "parameters": {
        "jsCode": "const timeData = $('Check Time Window').item.json;\nconst countResult = $json.result;\nconst count = (countResult !== null && countResult !== undefined) ? parseInt(countResult) : 0;\nconst okToGenerate = timeData.inTimeWindow && count < 2;\nreturn [{ json: { localHour: timeData.localHour, dateKey: timeData.dateKey, dailyCount: count, inTimeWindow: timeData.inTimeWindow, okToGenerate } }];"
      }
    },
    {
      "id": "vid-check4",
      "name": "IF OK to Generate",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1000, 300],
      "parameters": {
        "conditions": {
          "boolean": [{ "value1": "={{ $json.okToGenerate }}", "value2": true }]
        }
      }
    },
    {
      "id": "vid-2",
      "name": "RPOP script_queue",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1200, 300],
      "parameters": {
        "method": "POST",
        "url": "https://wealthy-hyena-4511.upstash.io/rpop/p2:script_queue",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "Bearer ARGfAAImcDE5NTI1MGEzYzhjMjQ0ZWM1YTFkYjY0ZmIxOTBhNmQ4YnAxNDUxMQ" }]
        }
      }
    },
    {
      "id": "vid-2b",
      "name": "IF Queue Not Empty",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1400, 300],
      "parameters": {
        "conditions": {
          "string": [{ "value1": "={{ $json.result }}", "operation": "isNotEmpty" }]
        }
      }
    },
    {
      "id": "vid-3",
      "name": "Load Job",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1600, 300],
      "parameters": {
        "method": "GET",
        "url": "https://wealthy-hyena-4511.upstash.io/get/p2:job:{{ $json.result }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "Bearer ARGfAAImcDE5NTI1MGEzYzhjMjQ0ZWM1YTFkYjY0ZmIxOTBhNmQ4YnAxNDUxMQ" }]
        }
      }
    },
    {
      "id": "vid-3b",
      "name": "IF Job Data Exists",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1800, 300],
      "parameters": {
        "conditions": {
          "string": [{ "value1": "={{ $json.result }}", "operation": "isNotEmpty" }]
        }
      }
    },
    {
      "id": "vid-3c",
      "name": "Decode Job",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 300],
      "parameters": {
        "jsCode": "const raw = $input.first().json.result;\nlet job;\ntry { job = JSON.parse(decodeURIComponent(raw)); } catch(e) { throw new Error('Decode failed: ' + e.message); }\nconst sizeMap = { '9x16':'480*848', '16x9':'848*480', '1x1':'480*480' };\nconst size = sizeMap[job.aspect_ratio] || '480*848';\nconst scenes = (job.script && job.script.scenes) ? job.script.scenes : [];\nreturn [{ json: { ...job, videoSize: size, scenes } }];"
      }
    },
    {
      "id": "vid-s1",
      "name": "Submit Scene 1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2200, 100],
      "parameters": {
        "method": "POST",
        "url": "https://api.wavespeed.ai/api/v3/wavespeed-ai/wan-2.2/t2v-480p-ultra-fast",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer 7b7eb45a4a6b3b88f137789db8cff7020e250e47938a8dddcb50d549fc177afc" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "{\n  \"prompt\": \"{{ $('Decode Job').item.json.scenes[0].visual_prompt }}, {{ $('Decode Job').item.json.visualPrompt }}, vertical video format\",\n  \"negative_prompt\": \"text, watermark, logo, blurry, cartoon\",\n  \"size\": \"{{ $('Decode Job').item.json.videoSize }}\",\n  \"duration\": {{ $('Decode Job').item.json.scenes[0].duration_sec || 7 }},\n  \"seed\": -1,\n  \"enable_safety_checker\": false\n}"
      }
    },
