    {
      "id": "vid-6",
      "name": "Build Render Package",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2450, 400],
      "parameters": {
        "jsCode": "const job = $('Decode Job').item.json;\nconst s1 = $('Submit Scene 1').item.json;\nconst s2 = $('Submit Scene 2').item.json;\nconst s3 = $('Submit Scene 3').item.json;\nconst s4 = $('Submit Scene 4').item.json;\nconst s5 = $('Submit Scene 5').item.json;\nconst vo = $('Submit Voice Job').item.json;\n\nconst pkg = {\n  job_id: job.jobId,\n  selectedTopic: job.selectedTopic || job.script?.title,\n  title: job.script?.title || job.selectedTopic,\n  genre: job.genre,\n  aspect_ratio: job.aspect_ratio,\n  duration: job.duration,\n  chatId: job.chatId,\n  narration: job.script?.full_narration,\n  scene_pred_ids: [\n    s1.data?.id || null,\n    s2.data?.id || null,\n    s3.data?.id || null,\n    s4.data?.id || null,\n    s5.data?.id || null\n  ],\n  voice_pred_id: vo.data?.id || null,\n  music_url: job.music_url || job.music || null,\n  vstyle: job.vstyle,\n  nstyle: job.nstyle,\n  created_at: new Date().toISOString(),\n  poll_attempts: 0\n};\nreturn [{ json: pkg }];"
      }
    },
