# KLIPORA — copy to .env and fill in (do not commit .env)

# Mission Control API (Railway)
MISSION_CONTROL_URL=https://domainbuddy7-web-klipora-production.up.railway.app

# Telegram Mission Console bot (run locally: python -m Command_Center.telegram_command_center)
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather
TELEGRAM_CHAT_ID=your_chat_id
OWNER_TELEGRAM_ID=your_telegram_user_id

# n8n (for upload_wf_assemble.py)
N8N_URL=https://n8n-production-2762.up.railway.app
N8N_API_KEY=your_n8n_api_key

# Optional: Railway Render (defaults in code if not set)
# RAILWAY_RENDER_URL=https://klipora-render-service-production.up.railway.app

# Redis (only if running API locally; Railway uses env)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token
